ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-5
# Knowledge-base index for grounded edits, optional; edits run ungrounded
# without one. Local dev reads a file; deployed reads a private Vercel Blob
# via BLOB_READ_WRITE_TOKEN, which Vercel injects when the store is linked.
KB_INDEX_PATH=
BLOB_READ_WRITE_TOKEN=
